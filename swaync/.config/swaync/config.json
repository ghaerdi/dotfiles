	"cssPriority": "user",
	"control-center-margin-bottom": 40,
	"timeout": 5,
	"timeout-low": 3,
	"fit-to-screen": true,
	"control-center-width": 470,
	"notification-window-width": 470,
	"image-visibility": "always",
	"widgets": [
