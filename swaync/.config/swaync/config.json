		"buttons-grid": {
			"buttons-per-row": 4,
			"actions": [
				{
					"label": "¾░Ś╝",
					"command": "hyprctl dispatch exit"
				},
				{
					"label": "¾░Źü",
					"command": "hyprlock"
				},
				{
					"label": "¾░£ē",
					"command": "reboot"
