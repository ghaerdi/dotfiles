{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/dotfiles/opencode/.config/opencode/docs/subagent-workflow.md",
    "~/dotfiles/opencode/.config/opencode/docs/sequential-thinking-guide.md"
  ],
  "mcp": {
    "chrome-devtools": {
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--executablePath",
        "/home/ghaerdi/.nix-profile/bin/brave",
        "--isolated"
      ],
      "type": "local"
    },
    "context7": {
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "excalidraw": {
      "type": "remote",
      "url": "https://mcp.excalidraw.com"
    },
    "microsoft-learn": {
      "type": "remote",
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "sequential-thinking": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "type": "local"
    },
    "time": {
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "LOCAL_TIMEZONE",
        "mcp/time"
      ],
      "type": "local"
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "oauth": {}
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {}
    },
    "mongo": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mongodb-mcp-server",
        "--readOnly"
      ],
			"environment": {
				"MDB_MCP_CONNECTION_STRING": "mongodb://127.0.0.1:27017/clinic1?directConnection=true"
			}
    }
  },
  "plugin": [
    "opencode-gemini-auth@latest",
    "@tarquinen/opencode-dcp@latest",
    "opencode-pty",
    "oh-my-openagent"
  ],
  "provider": {
    "ollama": {
      "models": {
        "deepseek-v3.2:cloud": {
          "limit": {
            "context": 163840,
            "output": 65536
          },
          "name": "deepseek-v3.2:cloud"
        },
        "glm-5:cloud": {
          "limit": {
            "context": 198000,
            "output": 32768
          },
          "name": "glm-5:cloud"
        },
        "kimi-k2.5:cloud": {
          "limit": {
            "context": 262144,
            "output": 32768
          },
          "name": "kimi-k2.5:cloud"
        },
        "minimax-m2.7:cloud": {
          "limit": {
            "context": 204800,
            "output": 128000
          },
          "name": "minimax-m2.7:cloud"
        },
        "qwen3.5:cloud": {
          "limit": {
            "context": 262144,
            "output": 32768
          },
          "name": "qwen3.5:cloud"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    }
  }
}
