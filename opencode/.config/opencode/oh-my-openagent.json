{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "ollama/qwen3.5:397b-cloud",
			"variant": "high"
    },
    "prometheus": {
      "model": "ollama/glm-5:cloud",
      "variant": "high"
    },
    "hephaestus": {
      "model": "google/gemini-3.1-pro-preview",
			"variant": "high",
      "fallback_models": [
        "ollama/devstral-2:cloud",
        "ollama/glm-5:cloud"
      ]
    },
    "oracle": {
      "model": "ollama/glm-5:cloud",
      "variant": "high"
    },
    "atlas": {
      "model": "ollama/deepseek-v3.2:cloud"
    },
    "momus": {
      "model": "ollama/qwen3.5:397b-cloud",
      "variant": "high"
    },
    "metis": {
      "model": "ollama/qwen3.5:cloud"
    },
    "explore": {
      "model": "ollama/minimax-m2.7:cloud"
    },
    "librarian": {
      "model": "ollama/minimax-m2.7:cloud"
    },
    "multimodal-looker": {
      "model": "ollama/qwen3.5:397b-cloud"
    },
    "sisyphus-junior": {
      "model": "ollama/devstral-2:cloud"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "ollama/kimi-k2.5:cloud",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "ollama/glm-5:cloud",
      "variant": "xhigh"
    },
    "deep": {
      "model": "ollama/devstral-2:cloud",
      "variant": "medium"
    },
    "artistry": {
      "model": "ollama/qwen3.5:397b-cloud",
      "variant": "high"
    },
    "quick": {
      "model": "ollama/minimax-m2.7:cloud"
    },
    "unspecified-high": {
      "model": "ollama/qwen3.5:397b-cloud"
    },
    "unspecified-low": {
      "model": "ollama/minimax-m2.7:cloud"
    },
    "writing": {
      "model": "ollama/qwen3.5:cloud"
    }
  },
  "background_task": {
    "providerConcurrency": {
      "ollama": 10,
      "google": 5
    }
  }
}
